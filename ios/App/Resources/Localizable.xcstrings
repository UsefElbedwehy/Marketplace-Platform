    "The feed lands in Phase 6 — this proves the themed tab shell today." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيتم إضافة الواجهة الرئيسية في المرحلة السادسة — هذا يثبت هيكل التبويبات المتوافق مع الهوية البصرية اليوم."
          }
        }
      }
    },
    "Dynamic filters from category attributes land in Phase 4." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الفلاتر الديناميكية من خصائص الفئات ستُضاف في المرحلة الرابعة."
          }
        }
      }
    },
    "The schema-driven create-listing flow lands in Phase 4." : {
